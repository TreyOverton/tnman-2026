---
import PortalLayout from '~/layouts/PortalLayout.astro';
---
<PortalLayout title="Send Broadcast" active="admin" adminOnly>
  <p class="muted small"><a href="/admin">&larr; Admin</a></p>
  <h1>Send Broadcast</h1>
  <p class="muted">
    Post a banner that every signed-in participant sees at the top of the portal
    until they dismiss it (per-session). Use sparingly. Severity controls color.
  </p>

  <form id="bc-form" class="card" onsubmit="return false;">
    <label for="bc-msg">Message</label>
    <input id="bc-msg" type="text" maxlength="240" placeholder="e.g. ICP IOC at 1600 — verify CalTopo location before reporting." />

    <div class="spacer"></div>
    <label for="bc-sev">Severity</label>
    <select id="bc-sev">
      <option value="info">Info</option>
      <option value="warning">Warning</option>
      <option value="urgent">Urgent</option>
    </select>

    <div class="spacer"></div>
    <div class="row">
      <button id="bc-send" class="primary" type="submit">Send broadcast</button>
      <span id="bc-status" class="muted small"></span>
    </div>
  </form>

  <h2>Active broadcasts</h2>
  <p class="muted">Toggle <em>active</em> to retract a banner without deleting history.</p>
  <div id="bc-list" class="feed"></div>
  <p id="bc-empty" class="muted" hidden>No active broadcasts.</p>

  <script>
    import { getFirebase } from '~/lib/firebase';
    import {
      collection, addDoc, serverTimestamp, query, orderBy, limit, onSnapshot,
      doc, updateDoc,
    } from 'firebase/firestore';

    const msgEl = document.getElementById('bc-msg') as HTMLInputElement;
    const sevEl = document.getElementById('bc-sev') as HTMLSelectElement;
    const sendBtn = document.getElementById('bc-send') as HTMLButtonElement;
    const statusEl = document.getElementById('bc-status')!;
    const listEl = document.getElementById('bc-list')!;
    const emptyEl = document.getElementById('bc-empty')!;

    function fmtTs(ts: any): string {
      if (!ts) return '…';
      const d = ts.toDate ? ts.toDate() : new Date(ts);
      return d.toLocaleString();
    }
    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      } as Record<string, string>)[c]!);
    }

    sendBtn.addEventListener('click', async () => {
      const message = msgEl.value.trim();
      if (!message) {
        statusEl.textContent = 'Enter a message.';
        return;
      }
      const email = document.body.dataset.email;
      const displayName = document.body.dataset.displayName || email;
      sendBtn.disabled = true;
      statusEl.textContent = 'Sending…';
      try {
        const { db } = getFirebase();
        await addDoc(collection(db, 'broadcasts'), {
          message,
          severity: sevEl.value,
          active: true,
          timestamp: serverTimestamp(),
          author: displayName,
          authorEmail: email,
        });
        msgEl.value = '';
        statusEl.textContent = 'Sent.';
        setTimeout(() => (statusEl.textContent = ''), 2200);
      } catch (e: any) {
        statusEl.textContent = e.message || 'Send failed.';
      } finally {
        sendBtn.disabled = false;
      }
    });

    document.addEventListener('portal:auth', () => {
      const { db } = getFirebase();
      const q = query(collection(db, 'broadcasts'), orderBy('timestamp', 'desc'), limit(50));
      onSnapshot(q, (snap) => {
        if (snap.empty) {
          listEl.innerHTML = '';
          emptyEl.hidden = false;
          return;
        }
        emptyEl.hidden = true;
        listEl.innerHTML = snap.docs.map((d) => {
          const x = d.data();
          const sev = String(x.severity || 'info');
          const active = x.active !== false;
          return `<div class="feed-entry" data-id="${d.id}">
            <div class="meta">
              <span class="who">${escapeHtml(String(x.author || x.authorEmail || ''))}</span>
              <span>${fmtTs(x.timestamp)}</span>
              <span>severity: ${sev}</span>
              <span>${active ? 'ACTIVE' : 'retracted'}</span>
            </div>
            <div class="body">${escapeHtml(String(x.message || ''))}</div>
            <div class="row" style="margin-top:8px;">
              <button data-action="toggle" data-id="${d.id}" data-active="${active ? '1' : '0'}">${active ? 'Retract' : 'Reactivate'}</button>
            </div>
          </div>`;
        }).join('');

        listEl.querySelectorAll('button[data-action="toggle"]').forEach((b) => {
          b.addEventListener('click', async () => {
            const id = b.getAttribute('data-id')!;
            const active = b.getAttribute('data-active') === '1';
            (b as HTMLButtonElement).disabled = true;
            await updateDoc(doc(db, 'broadcasts', id), { active: !active });
          });
        });
      });
    }, { once: true });
  </script>
</PortalLayout>
